#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
MANIFEST_PATH="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles/manifest"

cd "$DIR"

if [[ -f "$MANIFEST_PATH" ]]; then
  "$DIR/uninstall"
fi

mkdir -p "$(dirname "$MANIFEST_PATH")"
: > "$MANIFEST_PATH"

while IFS= read -r src; do
  link="$HOME/${src#home/}"

  if [[ -e "$link" && ! -L "$link" ]]; then
    echo "エラー: $link は管理外のファイルです。手動で確認してください。" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$link")"
  ln -sf "$DIR/$src" "$link"
  printf "%s\n" "$link" >> "$MANIFEST_PATH"
done < <(find home \( -type f -o -type l \))
