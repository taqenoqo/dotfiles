#!/usr/bin/env bash
set -euo pipefail

MANIFEST_PATH="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles/manifest"

if [[ ! -f "$MANIFEST_PATH" ]]; then
  echo "マニフェストが見つかりません: $MANIFEST_PATH" >&2
  exit 1
fi

while IFS=$'\t' read -r type path; do
  case "$type" in
    link)
      [[ -L "$path" ]] && rm "$path"
      ;;
    dir)
      rmdir "$path" 2>/dev/null || true
      ;;
  esac
done < "$MANIFEST_PATH"

rm "$MANIFEST_PATH"
