#!/usr/bin/env bash
set -euo pipefail

MANIFEST_PATH="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles/manifest"

if [[ ! -f "$MANIFEST_PATH" ]]; then
  echo "マニフェストが見つかりません: $MANIFEST_PATH" >&2
  exit 1
fi

while IFS= read -r link; do
  if [[ -L "$link" ]]; then
    rm "$link"
  elif [[ -e "$link" ]]; then
    echo "警告: $link はシンボリックリンクではないためスキップします。" >&2
  fi

  cur_dir="$(dirname "$link")"
  while [[ "$cur_dir" != "$HOME" && "$cur_dir" != "/" ]]; do
    if ! rmdir "$cur_dir" 2>/dev/null; then
      break
    fi
    cur_dir="$(dirname "$cur_dir")"
  done
done < "$MANIFEST_PATH"

rm "$MANIFEST_PATH"
