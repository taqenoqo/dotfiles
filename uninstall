#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

remove_empty_dirs() {
  # 子を先に処理しないと親の rmdir が失敗するため、深い順（sort -r）で走査する
  local dirs
  dirs=$(find home -mindepth 1 -type d | sort -r)

  while read -r dir; do
    target="$HOME/${dir#home/}"
    if [[ -d "$target" && -z "$(ls -A "$target")" ]]; then
      rmdir "$target"
    fi
  done <<< "$dirs"
}

stow --no-folding -D -t ~ home
remove_empty_dirs
